# =========================================================================
# ENVIRONMENT CONFIGURATION (MOBILE)
# =========================================================================
# ⚠️ SECURITY WARNING:
# Any variable prefixed with 'EXPO_PUBLIC_' will be baked into the 
# client bundle and IS NOT SECURE. 
#
# Sensitive secrets (like bypass tokens or private API keys) MUST NOT 
# have the 'EXPO_PUBLIC_' prefix. Access them via a secure backend.
# =========================================================================

# API Configuration (Publicly accessible by the app)
EXPO_PUBLIC_API_BASE_URL=http://your-local-ip:3001/api
EXPO_PUBLIC_CURRENCY_API_URL=https://sp-today.com/api/v1/latest/USD

# Third-party Integrations (Public)
EXPO_PUBLIC_TELEGRAM_BOT_USERNAME=YourBotName
